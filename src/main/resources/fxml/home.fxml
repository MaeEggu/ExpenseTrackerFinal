<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane prefHeight="720.0" prefWidth="1100.0" styleClass="app-root" stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.HomeController">
    <left>
        <VBox prefWidth="248.0" spacing="18.0" styleClass="sidebar">
            <padding>
                <Insets bottom="28.0" left="22.0" right="22.0" top="28.0" />
            </padding>
            <VBox spacing="6.0" styleClass="sidebar-brand">
                <Label text="Expense Tracker" styleClass="sidebar-title" />
                <Label text="Smart daily spending" styleClass="sidebar-subtitle" />
            </VBox>
            <Region prefHeight="12.0" />
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#showHome" text="Home"
                    contentDisplay="LEFT" graphicTextGap="12.0" styleClass="nav-button-active">
                <graphic>
                    <SVGPath content="M4 11 L12 4 L20 11 L20 20 L15 20 L15 14 L9 14 L9 20 L4 20 Z"
                             styleClass="nav-svg-active" />
                </graphic>
            </Button>
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#showAddExpense" text="Add Expense"
                    contentDisplay="LEFT" graphicTextGap="12.0" styleClass="nav-button">
                <graphic>
                    <SVGPath content="M12 5 L12 19 M5 12 L19 12" styleClass="nav-svg" />
                </graphic>
            </Button>
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#showViewExpense" text="View Expenses"
                    contentDisplay="LEFT" graphicTextGap="12.0" styleClass="nav-button">
                <graphic>
                    <SVGPath content="M7 3 L17 3 Q19 3 19 5 L19 21 L5 21 L5 5 Q5 3 7 3 Z M8 8 L16 8 M8 12 L16 12 M8 16 L13 16"
                             styleClass="nav-svg" />
                </graphic>
            </Button>
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#showEditExpense" text="Edit Expense"
                    contentDisplay="LEFT" graphicTextGap="12.0" styleClass="nav-button">
                <graphic>
                    <SVGPath content="M7 3 L15 3 Q17 3 17 5 L17 10 M5 5 L5 21 L15 21 M8 8 L14 8 M8 12 L12 12 M13 17 L18 12 L20 14 L15 19 L12 20 Z"
                             styleClass="nav-svg" />
                </graphic>
            </Button>
            <Region VBox.vgrow="ALWAYS" />
            <VBox spacing="4.0" styleClass="sidebar-note">
                <Label text="Current Base" styleClass="sidebar-note-label" />
                <Label text="PHP" styleClass="sidebar-note-value" />
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="14.0" styleClass="home-dashboard-section">
            <VBox spacing="5.0">
                <Label text="Expense Tracker" styleClass="page-title" />
                <Label text="Welcome back. Here is the current state of your expense workspace."
                       wrapText="true" styleClass="page-subtitle" />
                <Label fx:id="dateTimeLabel" text="Loading date and time..." styleClass="home-date-time" />
            </VBox>

            <GridPane hgap="14.0" vgap="14.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="42.0" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="28.0" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="30.0" />
                </columnConstraints>

                <VBox spacing="7.0" styleClass="stat-card-primary" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="Total Expenses" styleClass="stat-card-label" />
                    <Label fx:id="totalExpensesValueLabel" text="PHP 0.00" styleClass="stat-card-total" />
                </VBox>

                <VBox spacing="7.0" styleClass="stat-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Transactions" styleClass="stat-card-label" />
                    <Label fx:id="totalTransactionsValueLabel" text="0" styleClass="stat-card-value" />
                </VBox>

                <VBox spacing="7.0" styleClass="stat-card" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <Label text="Latest Expense Date" styleClass="stat-card-label" />
                    <Label fx:id="recentExpenseDateValueLabel" text="No records yet" wrapText="true"
                           styleClass="stat-card-value-small" />
                </VBox>
            </GridPane>

            <VBox spacing="10.0" prefHeight="210.0" maxHeight="230.0" styleClass="activity-dashboard-card">
                <VBox spacing="3.0">
                    <Label text="Recent Activity" styleClass="section-title-large" />
                    <Label text="Latest add, update, and delete actions from this app session." styleClass="muted-text" />
                </VBox>
                <VBox fx:id="activityTimelineBox" spacing="7.0" />
            </VBox>

            <VBox spacing="10.0" styleClass="database-status-card">
                <Label text="Database Status" styleClass="section-title-large" />
                <HBox alignment="CENTER_LEFT" spacing="9.0">
                    <Region styleClass="status-dot" />
                    <Label fx:id="databaseStatusValueLabel" text="Disconnected" styleClass="database-status-text" />
                    <Label text="to" styleClass="database-muted-text" />
                    <Label fx:id="databaseProviderValueLabel" text="Supabase PostgreSQL" styleClass="database-provider-text" />
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="8.0">
                    <Label text="Total Records:" styleClass="database-muted-text" />
                    <Label fx:id="totalRecordsValueLabel" text="0" styleClass="database-provider-text" />
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>